# Gmail (uses App Password, not regular password)
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# SMS Gateway (Google Fi: number@msg.fi.google.com)
SMS_GATEWAY=your_phone_number@msg.fi.google.com

# Allowed sender address (to validate incoming commands)
ALLOWED_SENDER=your_phone_number@msg.fi.google.com

# Genesis Connected Services
GENESIS_USERNAME=your-genesis-email@example.com
GENESIS_PASSWORD=your-genesis-password
GENESIS_PIN=0000
GENESIS_VIN=your-vin-number

# Command PIN (required in every text message)
COMMAND_PIN=0000

# API Key (for iOS Shortcuts / Google Home / IFTTT)
API_KEY=generate-with-openssl-rand-hex-32

# Polling interval in milliseconds (default: 30 seconds)
POLL_INTERVAL_MS=30000
